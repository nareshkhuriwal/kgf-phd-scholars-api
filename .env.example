APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Paper/file storage
AZURE_STORAGE_DISK=azure
PAPERS_UPLOAD_DISK=azure
# true = read paper files only from PAPERS_UPLOAD_DISK (Azure). Set false only for local legacy debugging.
PAPERS_STRICT_UPLOAD_DISK_ONLY=true
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=papers

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://phd.khuriwalgroup.com,https://scholars.khuriwalgroup.com
